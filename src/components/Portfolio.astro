---
import portfolioData from '@data/portfolio.json';
---
import portfolioData from '../data/portfolio.json';

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Portfolio',
  description = 'Contenido diseñado para convertir.'
} = Astro.props;

// Group by category
const categories = [...new Set(portfolioData.map(p => p.category))];
---

<section class="portfolio" id="portfolio">
  <div class="container mx-auto px-4">
    {/* Section Header */}
    <div class="section-header text-center mb-16">
      <h2>{title}</h2>
      <div class="divider-small mx-auto my-4"></div>
      <p class="text-lg text-gray-600">{description}</p>
    </div>

    {/* Portfolio Grid */}
    <div class="portfolio-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {portfolioData.map((project) => (
        <div class="portfolio-item group relative overflow-hidden rounded-lg shadow-subtle hover:shadow-hover transition-all duration-300">
          {/* Image / Video Preview */}
          <div class="portfolio-media relative w-full h-64 bg-light-card overflow-hidden">
            {project.video ? (
              <video
                src={project.video}
                poster={project.image}
                class="w-full h-full object-cover"
                controls
              />
            ) : (
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            )}

            {/* Overlay */}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-300 flex items-center justify-center">
              {project.video && (
                <div class="text-white opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              )}
            </div>
          </div>

          {/* Content */}
          <div class="p-4">
            <div class="flex items-center gap-2 mb-2 text-xs text-accent font-semibold uppercase tracking-wide">
              {project.brands.map((brand) => (
                <span key={brand}>{brand}</span>
              ))}
            </div>

            <h3 class="font-serif font-bold text-lg mb-2 text-primary group-hover:text-accent transition-colors">
              {project.title}
            </h3>

            <p class="text-sm text-gray-600 mb-4">
              {project.description}
            </p>

            {/* Tags */}
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span
                  key={tag}
                  class="text-xs px-2 py-1 bg-light-card text-gray-700 rounded"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Brands collaboration */}
    <div class="mt-20 pt-16 border-t-2 border-accent/20">
      <p class="text-center text-sm font-semibold text-gray-600 mb-8">
        Colaboraciones con marcas de referencia:
      </p>
      <div class="brands-grid grid grid-cols-2 md:grid-cols-5 gap-8 items-center justify-items-center max-w-4xl mx-auto">
        <div class="text-center">
          <p class="font-semibold text-primary">Skeepers</p>
          <p class="text-xs text-gray-500">Agencia UGC</p>
        </div>
        <div class="text-center">
          <p class="font-semibold text-primary">YesStyle</p>
          <p class="text-xs text-gray-500">E-commerce</p>
        </div>
        <div class="text-center">
          <p class="font-semibold text-primary">Charlotte Tilbury</p>
          <p class="text-xs text-gray-500">Belleza</p>
        </div>
        <div class="text-center">
          <p class="font-semibold text-primary">Stylevana</p>
          <p class="text-xs text-gray-500">Fashion</p>
        </div>
        <div class="text-center">
          <p class="font-semibold text-primary">Rabanne</p>
          <p class="text-xs text-gray-500">Lujo</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .portfolio {
    padding: 120px 0;
    background-color: white;
  }

  @media (max-width: 768px) {
    .portfolio {
      padding: 60px 0;
    }
  }

  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .portfolio-item {
    background-color: white;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow-subtle);
    transition: var(--transition-smooth);
  }

  .portfolio-item:hover {
    box-shadow: var(--shadow-hover);
  }

  .portfolio-media {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  .portfolio-media img,
  .portfolio-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .divider-small {
    width: 60px;
    height: 2px;
    background-color: var(--color-accent);
  }

  .brands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 2rem;
  }
</style>
