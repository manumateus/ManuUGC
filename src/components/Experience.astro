---
import experienceData from '@data/experience.json';
---
import experienceData from '../data/experience.json';
---

<section class="experience" id="experiencia">
  <div class="container mx-auto px-4">
    <div class="section-header text-center mb-16">
      <h2>Mi Recorrido</h2>
      <div class="divider-small mx-auto my-4"></div>
      <p class="text-gray-600">Experiencia real, no promesas</p>
    </div>

    {/* Timeline */}
    <div class="experience-timeline max-w-3xl mx-auto">
      {experienceData.map((item, index) => (
        <div key={item.id} class="timeline-item flex gap-8 mb-12">
          {/* Timeline marker */}
          <div class="timeline-marker relative">
            <div class="marker-dot"></div>
            {index !== experienceData.length - 1 && <div class="marker-line"></div>}
          </div>

          {/* Content */}
          <div class="timeline-content pb-8 flex-1">
            <div class="flex items-start justify-between mb-2">
              <div>
                <h3 class="font-serif font-bold text-xl text-primary">
                  {item.role}
                </h3>
                <p class="text-accent font-semibold text-sm">
                  {item.company}
                </p>
              </div>
              <span class="text-xs text-gray-500 font-semibold">
                {item.period}
              </span>
            </div>

            <p class="text-gray-700 mb-3 leading-relaxed">
              {item.description}
            </p>

            <div class="insight-badge">
              <span class="insight-icon">💡</span>
              <span class="insight-text">{item.insight}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 120px 0;
    background-color: white;
  }

  @media (max-width: 768px) {
    .experience {
      padding: 60px 0;
    }
  }

  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .divider-small {
    width: 60px;
    height: 2px;
    background-color: var(--color-accent);
    margin: 1rem auto;
  }

  .experience-timeline {
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
    animation: fade-in 0.6s ease-out forwards;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    min-width: 40px;
  }

  .marker-dot {
    width: 16px;
    height: 16px;
    background-color: var(--color-accent);
    border-radius: 50%;
    border: 4px solid white;
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 10;
  }

  .marker-line {
    position: absolute;
    top: 16px;
    width: 2px;
    height: calc(100% + 2rem);
    background-color: var(--color-accent);
    opacity: 0.3;
    z-index: 1;
  }

  .timeline-content {
    padding-top: 0.5rem;
  }

  .timeline-content h3 {
    font-family: 'Playfair Display', serif;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .timeline-content .period {
    font-size: 0.875rem;
    color: #999;
  }

  .insight-badge {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-light-card);
    border-radius: 4px;
    border-left: 3px solid var(--color-accent);
  }

  .insight-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .insight-text {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .timeline-item {
      gap: 1rem;
    }

    .timeline-content h3 {
      font-size: 1rem;
    }
  }
</style>
