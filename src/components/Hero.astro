---
export interface Props {
  hasImage?: boolean;
}

const { hasImage = false } = Astro.props;
---

<section class="hero" id="hero">
  <div class="container mx-auto px-4">
    <div class={`hero-content ${hasImage ? 'grid-2' : ''}`}>
      {/* Text Content */}
      <div class="hero-text fade-in">
        <h1 class="hero-title">
          Contenido que parece real.<br />
          Porque lo es.<br />
          Pero estratégicamente diseñado para conectar y convertir.
        </h1>

        <p class="hero-subtitle">
          Creadora UGC | Consultora de Marketing Digital | Especialista en Conversión
        </p>

        <div class="divider-small"></div>

        <div class="cta-buttons flex gap-4 flex-wrap md:flex-nowrap">
          <button class="btn btn-primary cta-button" id="cta-brief">
            Enviar Brief
          </button>
          <button class="btn btn-secondary cta-button" id="cta-talk">
            Hablemos
          </button>
        </div>

        <p class="cta-microcopy">
          Cuéntame tu proyecto y exploraremos cómo crear contenido que venda
        </p>
      </div>

      {/* Image / Video Placeholder */}
      {hasImage && (
        <div class="hero-image fade-in">
          <img
            src="/images/hero-image.jpg"
            alt="Manuela Mateus - Creadora UGC"
            class="w-full h-full object-cover rounded"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 0;
  }

  .hero-content {
    display: grid;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 40px 0;
    }
  }

  .hero-title {
    font-size: 3rem;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: #666;
    font-weight: 300;
    letter-spacing: 0.5px;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    margin: 2rem 0;
  }

  .cta-button {
    flex: 1;
    @media (max-width: 640px) {
      flex: 1 1 calc(50% - 0.5rem);
    }
  }

  .cta-microcopy {
    font-size: 0.875rem;
    color: #999;
    font-weight: 300;
    line-height: 1.5;
  }

  .hero-image {
    width: 100%;
    height: 500px;
    background: linear-gradient(135deg, var(--color-light-bg) 0%, var(--color-light-card) 100%);
    border-radius: 4px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero-image {
      height: 300px;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
</style>

<script>
  const ctaBrief = document.getElementById('cta-brief');
  const ctaTalk = document.getElementById('cta-talk');

  ctaBrief?.addEventListener('click', () => {
    const contactSection = document.getElementById('contacto');
    contactSection?.scrollIntoView({ behavior: 'smooth' });
  });

  ctaTalk?.addEventListener('click', () => {
    window.location.href = 'mailto:manumateus.ugc@gmail.com?subject=Colaboración%20UGC';
  });
</script>
